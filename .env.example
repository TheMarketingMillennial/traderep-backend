# TradeRep Pro — SMS Server Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Set to false to use real Twilio (requires credentials below)
MOCK_MODE=true

# ─── Twilio Credentials (required when MOCK_MODE=false) ──────
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── Google Review Link ───────────────────────────────────────
# Get this from: Google Business Profile → Get more reviews → Share review form
GOOGLE_REVIEW_LINK=https://g.page/r/your-business-id/review
