# TradeRep Pro — SMS Server Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Set to false to use real Twilio (requires credentials below)
MOCK_MODE=true

# ─── Twilio Credentials (required when MOCK_MODE=false) ──────
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── Google Review Links ──────────────────────────────────────
# NOT configured here. Each company stores their own Google review
# link in Firestore under their company document (google_review_link field).
# The Flutter app reads it and includes it in the SMS body automatically.
# This server just sends whatever message body it receives.
